# Supabase Configuration  
# Diperlukan untuk fitur delivery driver system  
# Dapatkan credentials ini dari dashboard Supabase project Anda  
  
# URL Supabase project Anda (format: https://xxxxx.supabase.co)  
SUPABASE_URL=your_supabase_url_here  
  
# Service Role Key Supabase (secret key untuk server-side operations)  
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here 
